# Default local development environment variables.
# Single source of truth for all defaults — used by Docker Compose and generate-configs.sh.
# Override per-machine by exporting env vars before running generate-configs.sh.

# ── MySQL ──────────────────────────────────────────────────────────────────
MYSQL_ROOT_PASSWORD=root
MYSQL_DATABASE=scaffold

# ── Cassandra ─────────────────────────────────────────────────────────────
CASSANDRA_CLUSTER_NAME=LocalCluster
CASSANDRA_DATACENTER=datacenter1
CASSANDRA_RACK=rack1

# ── Redis ─────────────────────────────────────────────────────────────────
# (no auth required in local dev)

# ── Asynqmon ──────────────────────────────────────────────────────────────
# Web UI: http://localhost:8081 — connects to redis:6379

# ── Secret file variables ──────────────────────────────────────────────────
# DB_ADAPTER selects which database-secret template to render:
#   mysql    → database-secret.mysql.json.template    (default, port 3306)
#   postgres → database-secret.postgres.json.template (typical port 5432)
# Override via: DB_ADAPTER=postgres make local-env-setup
DB_ADAPTER=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=scaffold
DB_USER=root
DB_PASSWORD=root
DB_SSLMODE=disable

# ── PostgreSQL ────────────────────────────────────────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=scaffold

CASSANDRA_HOST=127.0.0.1
CASSANDRA_PORT=9042
CASSANDRA_KEYSPACE=scaffold
CASSANDRA_USERNAME=
CASSANDRA_PASSWORD=

REDIS_HOST=127.0.0.1
REDIS_PORT=6379

# ── App config variables ───────────────────────────────────────────────────
SECRET_PATH=evaluate/env/
APP_NAME=scaffold
APP_DOMAIN=localhost
APP_PORT=8080
APP_ENVIRONMENT=local
APP_CHANNEL=scaffold
DB_NAME_YAML=scaffold
CASSANDRA_NAME_YAML=scaffold
REDIS_NAME_YAML=scaffold

# ── HTTP ──────────────────────────────────────────────────────────────────
HTTP_SCHEME=http
HTTP_SESSION_TYPE=redis
HTTP_SESSION_KEY=scaffold_session
HTTP_SESSION_DOMAIN=localhost
HTTP_SESSION_EXPIRE_TIME=86400

# ── Language ──────────────────────────────────────────────────────────────
DEFAULT_LANGUAGE=en

# ── Logging ───────────────────────────────────────────────────────────────
LOG_PATH=alloc/logs
LOG_LEVEL=debug
STDIO_CAPTURE=false

# ── Profiler ──────────────────────────────────────────────────────────────
PROFILER_ENABLE=false
