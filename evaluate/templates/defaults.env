# Default local development environment variables.
# These are loaded by docker-compose and can be overridden per-machine
# by creating evaluate/templates/local.env (gitignored).

# ── MySQL ──────────────────────────────────────────────────────────────────
MYSQL_ROOT_PASSWORD=root
MYSQL_DATABASE=scaffold
MYSQL_USER=app
MYSQL_PASSWORD=app

# ── Cassandra ─────────────────────────────────────────────────────────────
CASSANDRA_CLUSTER_NAME=LocalCluster
CASSANDRA_DATACENTER=datacenter1
CASSANDRA_RACK=rack1

# ── Redis ─────────────────────────────────────────────────────────────────
# (redis-server uses no auth by default in local dev)

# ── Asynqmon ──────────────────────────────────────────────────────────────
# Web UI: http://localhost:8081
# Connects to the redis service above via REDIS_ADDR=redis:6379
